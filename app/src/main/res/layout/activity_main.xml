<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <!-- 背景图片（如果有自定义背景） -->
    <ImageView
        android:id="@+id/iv_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="@string/app_name"
        android:visibility="gone" />

    <!-- 主容器 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="@dimen/spacing_large">

        <!-- 顶部工具栏 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_large"
            app:cardCornerRadius="@dimen/corner_radius_large"
            app:cardElevation="@dimen/elevation_medium"
            app:cardBackgroundColor="@color/glass_background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_medium">

                <!-- 连接状态显示 -->
                <TextView
                    android:id="@+id/tv_device_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/label_no_device_connected"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_medium"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <!-- 配对按钮 -->
                <ImageButton
                    android:id="@+id/btn_pair"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/btn_pair_bluetooth"
                    android:src="@android:drawable/ic_menu_add"
                    android:tint="@color/white" />

                <!-- 设置按钮 -->
                <ImageButton
                    android:id="@+id/btn_settings"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="@dimen/spacing_small"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/btn_settings"
                    android:src="@android:drawable/ic_menu_preferences"
                    android:tint="@color/white" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 输入区域 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="@dimen/spacing_large"
            app:cardCornerRadius="@dimen/corner_radius_large"
            app:cardElevation="@dimen/elevation_medium"
            app:cardBackgroundColor="@color/glass_background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="@dimen/spacing_large">

                <!-- 输入提示 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_medium"
                    android:text="@string/tip_typing"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_small" />

                <!-- 主输入框 -->
                <EditText
                    android:id="@+id/et_input"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    style="@style/GlassEditText"
                    android:hint="@string/hint_input"
                    android:imeOptions="actionSend"
                    android:inputType="textMultiLine"
                    android:maxLines="20"
                    android:scrollbars="vertical"
                    android:textIsSelectable="true" />

                <!-- 回车模式提示 -->
                <TextView
                    android:id="@+id/tv_enter_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_medium"
                    android:text="@string/tip_enter_newline"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_small" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 操作按钮区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3">

            <!-- 退格按钮 -->
            <Button
                android:id="@+id/btn_backspace"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_small"
                style="@style/RoundedButton"
                android:text="⌫"
                android:textSize="20sp" />

            <!-- 发送按钮 -->
            <Button
                android:id="@+id/btn_send"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_weight="2"
                style="@style/RoundedButton"
                android:text="@string/btn_save"
                android:enabled="false" />
        </LinearLayout>
    </LinearLayout>

    <!-- 设备列表弹出层 -->
    <FrameLayout
        android:id="@+id/device_list_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="@dimen/spacing_xlarge"
            app:cardCornerRadius="@dimen/corner_radius_large"
            app:cardElevation="@dimen/elevation_large">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 标题栏 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/spacing_large"
                    android:text="@string/select_device_to_connect"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_large"
                    android:background="@color/primary"
                    android:gravity="center" />

                <!-- 设备列表 -->
                <ListView
                    android:id="@+id/lv_devices"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxHeight="400dp"
                    android:divider="@color/glass_border"
                    android:dividerHeight="1dp" />

                <!-- 扫描状态 -->
                <ProgressBar
                    android:id="@+id/pb_scanning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_margin="@dimen/spacing_large"
                    android:visibility="gone" />

                <!-- 空状态提示 -->
                <TextView
                    android:id="@+id/tv_no_devices"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/spacing_large"
                    android:text="@string/no_devices_found"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:visibility="gone" />

                <!-- 取消按钮 -->
                <Button
                    android:id="@+id/btn_cancel_scan"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_margin="@dimen/spacing_large"
                    style="@style/RoundedButton"
                    android:text="@string/btn_cancel" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </FrameLayout>

</FrameLayout>